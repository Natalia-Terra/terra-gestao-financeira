# config.js contém URL do Supabase + publishable key.
# A publishable key é desenhada para ficar pública no frontend
# (a segurança vem da RLS, não de a chave ser secreta), então é
# seguro versionar. A secret key (sb_secret_…) NUNCA deve aparecer aqui.

# Variáveis de ambiente
.env
.env.*
!.env.example

# Dependências (caso venhamos a usar npm no futuro)
node_modules/

# Artefatos de build
dist/
build/
.vercel/

# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/
.idea/
*.swp
*~

# Logs
*.log
npm-debug.log*
